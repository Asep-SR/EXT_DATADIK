{
  "manifest_version": 3,
  "name": "Datadik Ciamis Scraper Pro",
  "version": "1.2",
  "description": "Scrape data individu guru se-kabupaten Ciamis",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://datadik.kemendikdasmen.go.id/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://datadik.kemendikdasmen.go.id/manage*"],
      "js": ["xlsx.full.min.js", "content.js"],
      "css": ["style.css"]
    }
  ]
}